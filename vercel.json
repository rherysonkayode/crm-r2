{
  "rewrites": [
    {
      "source": "/catalogo/:userId",
      "destination": "/api/catalogo/:userId"
    },
    {
      "source": "/confirm-email",
      "destination": "/confirm-email.html"
    },
    {
      "source": "/((?!confirm-email|catalogo).*)",
      "destination": "/index.html"
    }
  ]
}